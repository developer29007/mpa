# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit it.
# For Railway, set these in each service's Variables tab (see values in the Railway column below).

# ── Shared ───────────────────────────────────────────────────────────────────

# Date of the ITCH file to process (MMDDYYYY)
ITCH_DATE=10302019

# Space-separated stock filter. Leave blank to process all stocks.
# ITCH_STOCKS=AAPL TSLA MSFT

# ── Service addresses ─────────────────────────────────────────────────────────
# Choose the value that matches your environment:
#
#   Inside docker-compose network:   kafka:9092
#   Local terminal (port-forwarded): localhost:9092
#   Railway:                         kafka.railway.internal:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Postgres DSN — set credentials to match your environment.
#
#   Inside docker-compose network:   postgresql://mpa:mpa@postgres:5432/mpa
#   Local terminal (port-forwarded): postgresql://mpa:mpa@localhost:5432/mpa
#   Railway:                         postgresql://mpa:<password>@postgres.railway.internal:5432/mpa
MPA_DSN=postgresql://mpa:mpa@localhost:5432/mpa

# ── Postgres (used by the postgres service itself) ────────────────────────────
POSTGRES_DB=mpa
POSTGRES_USER=mpa
POSTGRES_PASSWORD=mpa
