# Copy this to .env for local docker-compose usage.
# For Railway, set these in each service's Variables tab (see values in the Railway column below).

# ── Shared ───────────────────────────────────────────────────────────────────

# Date of the ITCH file to process (MMDDYYYY)
ITCH_DATE=10302019

# Space-separated stock filter. Leave blank to process all stocks.
# ITCH_STOCKS=AAPL TSLA MSFT

# ── Service addresses ─────────────────────────────────────────────────────────
# Local (docker-compose)          │  Railway
# ─────────────────────────────────┼──────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# Railway value: kafka.railway.internal:9092

MPA_DSN=postgresql://mpa:mpa@postgres:5432/mpa
# Railway value: postgresql://mpa:<password>@postgres.railway.internal:5432/mpa

# ── Postgres (used by the postgres service itself) ────────────────────────────
POSTGRES_DB=mpa
POSTGRES_USER=mpa
POSTGRES_PASSWORD=mpa
